# Optional display name shown in the footer and metadata
VITE_APP_NAME=Laura

# Optional API endpoint for contact form submissions
# Example: https://api.example.com/contact
VITE_CONTACT_ENDPOINT=

# Contact form timeout (milliseconds)
VITE_CONTACT_TIMEOUT_MS=5000

# --- Mistral chat configuration ---
# Feature flag to enable the chat widget
VITE_ENABLE_CHAT=false

# Required when VITE_ENABLE_CHAT=true
VITE_MISTRAL_API_KEY=

# Optional: mistral-small (default), mistral-medium, mistral-large
VITE_MISTRAL_MODEL=mistral-small

# Optional override for the chat API endpoint (defaults to /api/chat)
VITE_CHAT_ENDPOINT=/api/chat

# Chat request timeout (milliseconds)
VITE_CHAT_TIMEOUT_MS=5000

# Server-only (recommended) for the API proxy
# MISTRAL_API_KEY=your-server-key
# MISTRAL_MODEL=mistral-small

# --- Perplexity provider (optional, replaces Mistral when enabled) ---
# Set to true to route chat through Perplexity instead of Mistral.
# Requires an active Perplexity Pro subscription for API access.
VITE_ENABLE_PERPLEXITY=false

# Required when VITE_ENABLE_PERPLEXITY=true
VITE_PERPLEXITY_API_KEY=

# Optional: sonar (default) | sonar-pro | sonar-reasoning | sonar-reasoning-pro
# sonar-pro returns richer citations; sonar-reasoning adds chain-of-thought
VITE_PERPLEXITY_MODEL=sonar

# Optional: swap to any OpenAI-compatible endpoint (e.g. your own proxy)
VITE_PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Optional: request timeout in ms (default 10000 — sonar-pro can be slow)
VITE_PERPLEXITY_TIMEOUT_MS=10000
